# FounderOS Test Runner configuration
SUPABASE_URL=https://your-ref.supabase.co

# Global platform token — must match the PLATFORM_RUNNER_TOKEN secret set on the
# edge functions. One token, one hosted runner, serves all client projects.
RUNNER_TOKEN=founder_platform_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — only needed to stream screenshots to the live view.
SUPABASE_SERVICE_ROLE_KEY=

# Optional tuning
RUNNER_ID=
POLL_INTERVAL_MS=3000
MAX_STEPS=40
