# FounderOS Unified Runner — one runner for Ops, E2E tests and security scans.
SUPABASE_URL=https://your-ref.supabase.co

# Global platform runner token (matches PLATFORM_RUNNER_TOKEN on the edge fns,
# or a per-project ops token). One token, one runner, serves everything.
RUNNER_TOKEN=founder_platform_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Needed to stream E2E screenshots to the live view (optional for ops/security).
SUPABASE_SERVICE_ROLE_KEY=

# Optional
RUNNER_ID=
POLL_INTERVAL_MS=3000
